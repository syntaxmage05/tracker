<div class="flex items-center px-6 py-4" aria-label="Breadcrumb">
  <ol class="inline-flex items-center space-x-1 md:space-x-3">
    <li class="inline-flex items-center">
      <h2 class="text-lg font-semibold text-gray-800">
        Users
      </h2>
    </li>
  </ol>
</div>

<div class="flex justify-center px-4">
  <div class="w-full max-w-5xl p-6 bg-white rounded-lg border border-gray-200 shadow-sm">

    <h5 class="mb-6 text-xl font-semibold text-gray-800">
      <%= "Users in #{current_account.name}" %>
    </h5>

    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left text-gray-600">
        <thead class="text-xs text-gray-500 uppercase border-b">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Email</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Role</th>
            <th class="px-4 py-3">Added</th>
            <th class="px-4 py-3 text-right"></th>
          </tr>
        </thead>

        <tbody class="divide-y">
          <% @users.each do |user| %>
          <tr class="hover:bg-gray-50">

            <td class="px-4 py-3 font-medium text-gray-800">
              <%= user.name %>
            </td>

            <td class="px-4 py-3">
              <%= user.email %>
            </td>

            <td class="px-4 py-3">
              <% if user.accepted_or_not_invited? %>
                <span class="px-2 py-1 text-xs font-medium text-green-700 bg-green-100 rounded-full">
                  Active
                </span>
              <% else %>
                <span class="px-2 py-1 text-xs font-medium text-yellow-700 bg-yellow-100 rounded-full">
                  Invited
                </span>
              <% end %>
            </td>

            <td class="px-4 py-3">
              <%= user.roles&.first&.name&.capitalize %>
            </td>

            <td class="px-4 py-3">
              <%= user.created_at.strftime('%D') %>
            </td>

            <td class="px-4 py-3 text-right space-x-2">

              <%= link_to 'Edit',
                  edit_account_user_path(user),
                  class: 'text-sm text-blue-600 hover:underline' %>

              <%= link_to 'Destroy',
                  account_user_path(user),
                  { method: :delete,
                    data: { confirm: 'Are you sure?' },
                    class: 'text-sm text-red-600 hover:underline'
                  } unless user.id == current_user.id %>

            </td>

          </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-6">
      <%= link_to "Add User",
          new_account_user_path,
          class: "inline-flex items-center text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-md text-sm px-4 py-2" %>
    </div>

  </div>
</div>